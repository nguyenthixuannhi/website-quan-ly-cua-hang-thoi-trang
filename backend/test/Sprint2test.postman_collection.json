    {
      "name": "UI",
      "description": "UI configuration endpoints — banners and advertisements.",
      "item": [
        {
          "name": "Get Banners",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has all banner URLs', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('hero');",
                  "    pm.expect(json).to.have.property('loginBanner');",
                  "    pm.expect(json).to.have.property('signUpBanner');",
                  "});",
                  "",
                  "pm.test('Banner URLs point to the server', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.hero).to.match(/^http/);",
                  "    pm.expect(json.loginBanner).to.match(/^http/);",
                  "    pm.expect(json.signUpBanner).to.match(/^http/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ui/banners",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ui",
                "banners"
              ]
            },
            "description": "Get banner image URLs for the hero section, login page, and sign-up page."
          }
        },
