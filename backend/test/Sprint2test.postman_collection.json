    {
      "name": "DanhMuc (Categories)",
      "description": "Category management endpoints.",
      "item": [
        {
          "name": "Get All Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each item has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    if (json.length > 0) {",
                  "        json.forEach(item => {",
                  "            pm.expect(item).to.have.property('id_danh_muc');",
                  "            pm.expect(item).to.have.property('ten_danh_muc');",
                  "        });",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/danhmuc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "danhmuc"
              ]
            },
            "description": "Retrieve all danh muc (categories). Returns an array of category objects."
          }
        }
      ]
